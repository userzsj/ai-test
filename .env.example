# ========== 数据库配置 ==========
# 本地开发用 localhost，Docker 部署用 db
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/fastapi_db?charset=utf8mb4

# ========== JWT 配置 ==========
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========== 邮件配置（使用 QQ 邮箱） ==========
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_qq_authorization_code
MAIL_FROM=your_email@qq.com
MAIL_PORT=587
MAIL_SERVER=smtp.qq.com

# ========== Redis 配置 ==========
REDIS_URL=redis://localhost:6379/0

# ========== 应用配置 ==========
APP_NAME=用户管理系统 API
APP_VERSION=1.0.0
DEBUG=True
BASE_URL=http://127.0.0.1:8000

# ========== 环境配置 ==========
# development: 本地开发
# production:  生产部署
ENVIRONMENT=development